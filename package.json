{
  "name": "webify",
  "version": "1.0.0",
  "description": "Convert any image or video to WebP",
  "author": "Monteo",
  "main": "./dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.monteo.webpconverter",
    "productName": "WebP Converter",
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "category": "public.app-category.utilities",
      "identity": null
    },
    "win": {
      "target": ["nsis"]
    },
    "directories": {
      "output": "release"
    }
  }
}
